# ==========================================================================
# 454-backend — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores:  cp .env.example .env
# ==========================================================================

# --- Banco de dados (obrigatório) ----------------------------------------
# Local (Docker): a porta do host é 5433 (ver docker-compose.yml)
DATABASE_URL="postgresql://linq:linqq608U@localhost:5433/polls?schema=public"
# Conexão DIRETA para o `prisma migrate deploy` (Neon/Supabase com pooler).
# Em produção use a URL SEM "-pooler". Em local pode deixar vazio.
# DIRECT_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# --- Autenticação (obrigatório) ------------------------------------------
# Em produção: >= 32 caracteres e NÃO pode ser valor de exemplo.
# Gere com: openssl rand -base64 48
JWT_SECRET="troque-esta-chave-por-uma-forte-com-32-mais-caracteres"
JWT_EXPIRES_IN="8h"

# --- Servidor -------------------------------------------------------------
PORT=3000
NODE_ENV="development"

# --- CORS (obrigatório em produção) --------------------------------------
# Origens permitidas, separadas por vírgula, SEM barra no final.
CORS_ORIGIN="http://localhost:5173"

# --- URL pública da API (produção) ---------------------------------------
# Usada para montar URLs absolutas (ex.: logo). Ex.: https://454-backend.onrender.com
# PUBLIC_API_URL="https://sua-api.onrender.com"

# --- E-mail SMTP (opcional; necessário p/ enviar relatório por e-mail) ----
# Gmail com senha de app: https://support.google.com/accounts/answer/185833
# SMTP_USER="seu-email@gmail.com"
# SMTP_PASS="senha-de-app-do-gmail"

# --- Documentação Swagger em produção (opcional) -------------------------
# EXPOSE_API_DOCS=1  # expõe /api-docs mesmo com NODE_ENV=production

# --- Observabilidade / operação (opcional) -------------------------------
# OPS_REQUEST_LOG=1          # loga cada requisição HTTP em JSON
# TRUST_PROXY=1              # confia no proxy (já ativo quando NODE_ENV=production)

# --- Rate limit do login (opcional) --------------------------------------
# LOGIN_RATE_LIMIT_MAX=40
# LOGIN_RATE_LIMIT_WINDOW_MINUTES=15

# --- Puppeteer / Chromium (produção via Docker) --------------------------
# No Docker da imagem já vem configurado; local não precisa.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
